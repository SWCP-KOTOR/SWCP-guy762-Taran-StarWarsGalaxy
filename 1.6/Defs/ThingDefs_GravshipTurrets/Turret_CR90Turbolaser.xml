	<ThingDef ParentName="BaseWeaponTurret">
		<defName>guy762_SWGravshipTurretGun_CR90Turbolaser</defName>
		<label>dual turbolaser turret</label>
		<description>.</description>
		<graphicData>
			<texPath>Gravships/CR90Corvette/CR90gun_turbo</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(12,12)</drawSize>
		</graphicData>
		
		<altitudeLayer>WorldClipper</altitudeLayer>
		
		<statBases>
		  <AccuracyTouch>0.95</AccuracyTouch>
		  <AccuracyShort>0.90</AccuracyShort>
		  <AccuracyMedium>0.85</AccuracyMedium>
		  <AccuracyLong>0.80</AccuracyLong>
		  <RangedWeapon_Cooldown>3</RangedWeapon_Cooldown>
		  <DeteriorationRate>0</DeteriorationRate>
		  <Mass>2000</Mass>
		  <Flammability>0</Flammability>
		</statBases>
		
		<recoilPower>5</recoilPower>
		
		<verbs>
		  <li>
			<verbClass>Verb_Shoot</verbClass>
			<defaultProjectile>SWCPStarfighterBullet_AssaultAVAAturbo_dualred</defaultProjectile>
			<warmupTime>0.5</warmupTime>
			<minRange>5</minRange>
			<range>500</range>
			<burstShotCount>1</burstShotCount>
			<soundCast>kotorsound_turbolaser_LouderForTurrets</soundCast>
			<soundCastTail>GunTail_Heavy</soundCastTail>
			<muzzleFlashScale>18</muzzleFlashScale>
			<!-- <consumeFuelPerShot>1</consumeFuelPerShot> -->
			<forcedMissRadius>0</forcedMissRadius>
			<ai_AvoidFriendlyFireRadius>3</ai_AvoidFriendlyFireRadius>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
			<isMortar>true</isMortar>
		  </li>
		</verbs>
		<modExtensions>
		  <li Class="IgnoreConfigErrors.Ignore_ForcedMissRadius" />
		</modExtensions>
	</ThingDef>
  
  
  
  
