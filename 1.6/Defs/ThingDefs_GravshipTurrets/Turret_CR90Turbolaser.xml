			<turretGunDef>guy762_SWGravshipTurretGun_CR90Turbolaser</turretGunDef>
			<turretTopDrawSize>12</turretTopDrawSize>

			<turretBurstWarmupTime>1.5</turretBurstWarmupTime>
			<turretBurstCooldownTime>1</turretBurstCooldownTime>
