<?xml version="1.0" encoding="utf-8" ?>
<Defs>


  

  <!--=============== AA point-defense beam ===============-->

	<ThingDef ParentName="guy762_GravshipTurretBase">
		<defName>guy762_SWTurret_AAPointDefenseBeam</defName>
		<label>anti-air beam turret</label>
		<description>.</description>
		<graphicData>
		  <graphicClass>Graphic_Single</graphicClass>
		  <texPath>Turrets/Turrets_Ogam/HardpointBase</texPath>
		  <drawSize>(3,3)</drawSize>
		  <drawRotated>false</drawRotated>
		  
		  <damageData>
			<rect>(0.38,0.2,0.56375,0.8)</rect>
			<cornerTL>Damage/Corner</cornerTL>
		  </damageData>
		  <shadowData>
			<offset>(-0.13,-0.87,-0.1)</offset>
			<volume>(0.5,0.4,1.05)</volume>
		  </shadowData>
		</graphicData>
		<uiIconPath>Turrets/Turrets_Ogam/PointDefense_icon</uiIconPath>
		<!-- <rotatable>false</rotatable> -->

		
		<statBases>
		  <MaxHitPoints>250</MaxHitPoints>
		  
		  <ShootingAccuracyTurret>0.98</ShootingAccuracyTurret> <!-- like level 14 human shooter -->
		</statBases>
		
		<!-- <placeWorkers> -->
			<!-- <li>PlaceWorker_NotUnderRoof</li> -->
		<!-- </placeWorkers> -->
		<altitudeLayer>WorldClipper</altitudeLayer>
		
		<costList>
		  <Steel>300</Steel>
		  <Plasteel>30</Plasteel>
		  <Uranium>60</Uranium>
		  <ComponentIndustrial>6</ComponentIndustrial>
		</costList>
		
		<size>(2,2)</size>
		<fillPercent>0.8</fillPercent>
		<!-- <hasInteractionCell>True</hasInteractionCell> -->
		<!-- <interactionCellOffset>(1,0,3)</interactionCellOffset> -->
		
		<soundInteract>kotorsound_select_shipgun</soundInteract>
		<comps>
			<!-- <li Class="CompProperties_Mannable"> -->
				<!-- <manWorkType>Violent</manWorkType> -->
			<!-- </li> -->
		  
			<li Class="CompProperties_Explosive">
				<wickTicks>240</wickTicks>
				<explosiveRadius>3</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
				<chanceNeverExplodeFromDamage>0.5</chanceNeverExplodeFromDamage>
			</li>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>150</basePowerConsumption>
			</li>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_Breakdownable"/>
		</comps>
		
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<!-- <terrainAffordanceNeeded>Substructure</terrainAffordanceNeeded> -->
		<building>
			<turretGunDef>guy762_SWTurretGun_AAPointDefenseBeam</turretGunDef>
			<turretTopDrawSize>3</turretTopDrawSize>
			<!-- <turretTopOffset>(-0.05, 0.05)</turretTopOffset> -->
		  
			<turretBurstWarmupTime>0.125</turretBurstWarmupTime>
			<turretBurstCooldownTime>2.5</turretBurstCooldownTime>
		</building>
		<researchPrerequisites>
		  <li>SniperTurret</li>
		</researchPrerequisites>
	</ThingDef>








	<ThingDef ParentName="BaseWeaponTurret">
		<defName>guy762_SWTurretGun_AAPointDefenseBeam</defName>
		<label>anti-air beam turret</label>
		<description>.</description>
		<graphicData>
		  <texPath>Turrets/Turrets_Ogam/PointDefense_gun</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <drawSize>(2,2)</drawSize>
		</graphicData>
		<altitudeLayer>WorldClipper</altitudeLayer>
		
		<statBases>
		  <AccuracyTouch>0.30</AccuracyTouch>
		  <AccuracyShort>0.40</AccuracyShort>
		  <AccuracyMedium>0.80</AccuracyMedium>
		  <AccuracyLong>0.90</AccuracyLong>
		  <RangedWeapon_Cooldown>2.5</RangedWeapon_Cooldown>
		  <DeteriorationRate>0</DeteriorationRate>
		  <Mass>200</Mass>
		  <Flammability>0</Flammability>
		</statBases>
		<verbs>
		  <li>
			<verbClass>Verb_Shoot</verbClass>
			<defaultProjectile>SWVehicleBullet_ExProjDoubleBeam_AAred</defaultProjectile>
			<warmupTime>0.125</warmupTime>
			<!-- <range>90</range> normal ground defense range -->
			<range>250</range> <!-- ship defense range -->
			
			<burstShotCount>1</burstShotCount>
			<ticksBetweenBurstShots>6</ticksBetweenBurstShots>
			
			<soundCast>kotorsound_LAATi_beamturret_fire</soundCast>
			<soundCastTail>GunTail_Heavy</soundCastTail>
			<muzzleFlashScale>18</muzzleFlashScale>
			<forcedMissRadius>0</forcedMissRadius>
			<ai_AvoidFriendlyFireRadius>3</ai_AvoidFriendlyFireRadius>
			
			<!-- <onlyManualCast>true</onlyManualCast> DoubleContinuousBeam_red-->
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		  </li>
		</verbs>
		<modExtensions>
			<li Class="IgnoreConfigErrors.Ignore_ForcedMissRadius" />
		</modExtensions>
	</ThingDef>
	
	
	
	
	
	
	
	
	
	<ThingDef ParentName="SWCPStarfighterBullet_Interceptor_AntiAir_BASE">
		<defName>SWVehicleBullet_doublebeam_AAred</defName>
		<label>anti-air beam</label>
		<description>.</description>
		<thingClass>taranchuk_lasers.LaserProjectile</thingClass>
		<drawOffscreen>true</drawOffscreen>
		<seeThroughFog>true</seeThroughFog>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Weapons/Projectiles/DoubleContinuousBeam_red</texPath>
			<shaderType>TransparentPostLight</shaderType>
			<drawSize>2</drawSize>
		</graphicData>
		<projectile>
			<damageDef>guy762_BeamDamage_AntiVehicleEnergy</damageDef>
			<damageAmountBase>50</damageAmountBase>
			<armorPenetrationBase>1</armorPenetrationBase>
			<stoppingPower>5</stoppingPower>
			<speed>10000</speed>
		</projectile>
		<modExtensions>
			<li Class="taranchuk_lasers.LaserProperties">
				<damageTickRate>7</damageTickRate>
				<lifetimeTicks>10</lifetimeTicks>
				<beamWidth>0.5</beamWidth>
				<beamWidthDrawScale>3</beamWidthDrawScale>
				<sweepRatePerTick>0.25</sweepRatePerTick>
				<maxSweepAngle>0.25</maxSweepAngle>
				<damageThingsAcrossBeamLine>false</damageThingsAcrossBeamLine>
				<debugCells>false</debugCells>
				<groundFleckDef>Fleck_BeamBurn</groundFleckDef>
				<endEffecterDef>GraserBeam_End</endEffecterDef>
				<fleckChancePerTick>0.32</fleckChancePerTick>
				<textureScrollOffsetPerTick>(0, -0.1)</textureScrollOffsetPerTick>
				<lockOnTarget>true</lockOnTarget>
				
				<sustainerSoundDef>kotorsound_LAATi_beam_midair</sustainerSoundDef>
				<sustainerTickPeriod>100</sustainerTickPeriod>
				<trailSoundDef>GunTail_Medium</trailSoundDef>
			</li>
		</modExtensions>
	</ThingDef>
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	<VEF.Weapons.ExpandableProjectileDef ParentName="SWCPStarfighterBullet_Interceptor_AntiAir_BASE">
		<defName>SWVehicleBullet_ExProjDoubleBeam_AAred</defName>
		<label>anti-air laser beam</label>
		<thingClass>VEF.Weapons.ExpandableProjectile</thingClass>
		<graphicData>
			<texPath>Weapons/Projectiles/DoubleBeam_red</texPath>
			<texPathFadeOut>Weapons/Projectiles/DoubleBeam_red</texPathFadeOut>
			<shaderType>MoteGlow</shaderType>
		</graphicData>
		<projectile>
			<damageDef>guy762_BeamDamage_AntiVehicleEnergy</damageDef>
			<speed>1000</speed>
			<damageAmountBase>25</damageAmountBase>
			<stoppingPower>1</stoppingPower>
			<soundAmbient>kotorsound_LAATi_beam_midair</soundAmbient>
		</projectile>
		<dealsDamageOnce>false</dealsDamageOnce>
		
		<tickDamageRate>1</tickDamageRate>
		<lifeTimeDuration>150</lifeTimeDuration>
		
		
		<drawOffscreen>true</drawOffscreen>
		<widthScaleFactor>0.05</widthScaleFactor>
		<heightScaleFactor>1</heightScaleFactor>
		<startingPositionOffset>(0, 0, -1)</startingPositionOffset>
		<totalSizeScale>1.15</totalSizeScale>
		<tickFrameRate>30</tickFrameRate>
		<finalTickFrameRate>1</finalTickFrameRate>
		<minDistanceToAffect>0.5</minDistanceToAffect>
	</VEF.Weapons.ExpandableProjectileDef>

 

</Defs>