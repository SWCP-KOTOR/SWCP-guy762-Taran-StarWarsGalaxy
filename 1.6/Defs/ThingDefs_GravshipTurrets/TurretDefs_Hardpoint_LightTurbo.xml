<?xml version="1.0" encoding="utf-8" ?>
<Defs>


  

  <!--=============== light hardpoint Turbolaser ===============-->

	  <ThingDef ParentName="guy762_GravshipTurretBase">
		<defName>guy762_SWTurret_HardpointLightTurbo</defName>
		<label>hardpoint light Turbolaser</label>
		<description>.</description>
		<graphicData>
		  <graphicClass>Graphic_Single</graphicClass>
		  <texPath>Turrets/Turrets_Ogam/HardpointBase</texPath>
		  <drawSize>(4,4)</drawSize>
		  <drawRotated>false</drawRotated>
		  
		  <damageData>
			<rect>(0.38,0.2,0.56375,0.8)</rect>
			<cornerTL>Damage/Corner</cornerTL>
		  </damageData>
		  <shadowData>
			<offset>(-0.13,-0.87,-0.1)</offset>
			<volume>(0.5,0.4,1.05)</volume>
		  </shadowData>
		</graphicData>
		<uiIconPath>Turrets/Turrets_Ogam/TurbolaserHardpoint_icon</uiIconPath>
		<!-- <rotatable>false</rotatable> -->

		
		<statBases>
		  <MaxHitPoints>250</MaxHitPoints>
		  <ShootingAccuracyTurret>0.98</ShootingAccuracyTurret> <!-- like level 14 human shooter -->
		</statBases>
		
		
		
		<costList>
		  <Steel>300</Steel>
		  <Plasteel>30</Plasteel>
		  <Uranium>60</Uranium>
		  <ComponentIndustrial>6</ComponentIndustrial>
		</costList>
		
		<size>(3,3)</size>
		<fillPercent>0.8</fillPercent>
		<!-- <hasInteractionCell>True</hasInteractionCell> -->
		<!-- <interactionCellOffset>(0,0,3)</interactionCellOffset> -->
		
		<soundInteract>kotorsound_select_shipgun</soundInteract>
		<comps>
			<!-- <li Class="CompProperties_Mannable"> -->
				<!-- <manWorkType>Violent</manWorkType> -->
			<!-- </li> -->

			<li Class="CompProperties_Explosive">
				<wickTicks>240</wickTicks>
				<explosiveRadius>3</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
			<chanceNeverExplodeFromDamage>0.5</chanceNeverExplodeFromDamage>
			</li>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>150</basePowerConsumption>
			</li>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_Breakdownable"/>
		</comps>
		
		<recoilPower>3</recoilPower>
		
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<!-- <terrainAffordanceNeeded>Substructure</terrainAffordanceNeeded> -->
		<building>
			<turretGunDef>guy762_SWTurretGun_HardpointLightTurbo</turretGunDef>
			<turretTopDrawSize>6</turretTopDrawSize>
			<turretTopOffset>(-0.05, 0.05)</turretTopOffset>
		  
			<turretBurstWarmupTime>2.5</turretBurstWarmupTime>
			<turretBurstCooldownTime>2.5</turretBurstCooldownTime>
		</building>
		<researchPrerequisites>
		  <li>SWCPResearch_PLACEHOLDER</li>
		</researchPrerequisites>
	</ThingDef>








  <ThingDef ParentName="BaseWeaponTurret">
    <defName>guy762_SWTurretGun_HardpointLightTurbo</defName>
    <label>light Turbolaser</label>
    <description>.</description>
    <graphicData>
      <texPath>Turrets/Turrets_Ogam/Turbolaser_gun</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <drawSize>(6,6)</drawSize>
    </graphicData>
    <statBases>
      <AccuracyTouch>0.30</AccuracyTouch>
      <AccuracyShort>0.40</AccuracyShort>
      <AccuracyMedium>0.80</AccuracyMedium>
      <AccuracyLong>0.90</AccuracyLong>
      <RangedWeapon_Cooldown>2.5</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>200</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <defaultProjectile>SWFixedTurretBullet_AVheavydoublegreen</defaultProjectile>
        <warmupTime>2.5</warmupTime>
        <minRange>5</minRange>
        <range>500</range>
        <burstShotCount>1</burstShotCount>
        <soundCast>kotorsound_turbolaser</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>18</muzzleFlashScale>
        <!-- <consumeFuelPerShot>1</consumeFuelPerShot> -->
		<forcedMissRadius>0</forcedMissRadius>
		<ai_AvoidFriendlyFireRadius>3</ai_AvoidFriendlyFireRadius>
		
		<!-- <onlyManualCast>true</onlyManualCast> -->
		<targetParams>
			<canTargetLocations>true</canTargetLocations>
		</targetParams>
		<isMortar>true</isMortar>
      </li>
    </verbs>
	<modExtensions>
	  <li Class="IgnoreConfigErrors.Ignore_ForcedMissRadius" />
	</modExtensions>
  </ThingDef>

 

</Defs>