		<worldObjectDef>AsteroidBasic</worldObjectDef>
		<layerDefs>
		  <li>SWCPPlanetLayer_RhenVarOrbit</li>
		</layerDefs>
		<preciousResources>
		  <li>MineableGold</li>
		  <li>MineableSilver</li>
		  <li>MineableSteel</li>
		  <!-- <li>MineableUranium</li> -->
		  <!-- <li>MineablePlasteel</li> -->
		  <!-- <li>MineableComponentsIndustrial</li> -->
		  <li>MineableJade</li>
		  <!-- <li>KOTOR_MineableJunk</li> doesn't generate maps for some reason -->
		  <!-- <li>KOTOR_MineableDurasteel</li> -->
		  <li>KOTOR_MineableBronzium</li>
		  <li>KOTOR_MineableCortosis</li>
		  <!-- <li>KOTOR_MineableBeskar</li> -->
		  <!-- <li>KOTOR_MineableRhydonium</li> -->
		  <!-- <li>KOTOR_MineableSpice</li> -->
		</preciousResources>
	</GeneratedLocationDef>
	
	<PlanetLayerSettingsDef>
		<defName>SWCPPlanetLayer_RhenVarOrbit</defName> <!-- "defName of PlanetLayerDef, PlanetLayerSettingsDef and ScenPartDef must be same" -->
		<label>Rhen Var orbit</label>
		<settings>
			<radius>110</radius>
			<subdivisions>4</subdivisions> <!-- vanilla orbit has 5 -->
			<extraCameraAltitude>300</extraCameraAltitude>
			<backgroundWorldCameraOffset>160</backgroundWorldCameraOffset>
			<backgroundWorldCameraParallaxDistancePer100Cells>2.5</backgroundWorldCameraParallaxDistancePer100Cells>
			<useSurfaceViewAngle>true</useSurfaceViewAngle>
		</settings>
	</PlanetLayerSettingsDef>
	
	<ScenPartDef>
		<defName>SWCPPlanetLayer_RhenVarOrbit</defName> <!-- "defName of PlanetLayerDef, PlanetLayerSettingsDef and ScenPartDef must be same" -->
		<label>Rhen Var orbit layer type</label>
		<scenPartClass>ScenPart_PlanetLayerFixed</scenPartClass>
		<category>Fixed</category>
		<summaryPriority>100</summaryPriority>
		<canBeRandomlyAdded>false</canBeRandomlyAdded>
		<canBePlayerAddedRemoved>false</canBePlayerAddedRemoved>
	</ScenPartDef>
	
	<PlanetLayerDef ParentName="OrbitLayer">
		<defName>SWCPPlanetLayer_RhenVarOrbit</defName>
		<label>Rhen Var orbit</label>
		<viewGizmoTooltip>View locations that are orbiting Rhen Var.</viewGizmoTooltip>
		<viewGizmoTexPath>UI/Commands/ViewOrbit</viewGizmoTexPath>
		<elevationString>200km</elevationString>
		<defaultBiome>SWCPBiome_Orbit</defaultBiome>
		<rangeDistanceFactor>20</rangeDistanceFactor>
		
		<modExtensions>
			<li Class="LayeredAtmosphereOrbit.LayeredAtmosphereOrbitDefModExtension">
				<isOptionToAutoAdd>true</isOptionToAutoAdd>
				<isReplaceConnections>true</isReplaceConnections>
				<elevation>200</elevation>
				<tempOffest>-95</tempOffest>
				<planetLayerGroup>SWCPPlanetLayerGroup_RhenVar</planetLayerGroup>
			</li>
		</modExtensions>
	</PlanetLayerDef>
	
	
	
  
</Defs>
