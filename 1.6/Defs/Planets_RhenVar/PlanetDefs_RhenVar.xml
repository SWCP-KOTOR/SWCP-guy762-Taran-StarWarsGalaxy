<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	
	<LayeredAtmosphereOrbit.PlanetDef>
		<defName>SWCPPlanet_RhenVar</defName>
		<label>Rhen Var</label>
		<description>This place reminds me of you, Ulic...\n\nDistance to Rimworld: 375000 km.\nDiameter: 100% of Rimworld.\n\nGravity well elevation: 1000 km.</description>
		<viewGizmoTexPath>World/PlanetIcons/rhenvar</viewGizmoTexPath>
		
		<posFromRimworld>(1500000, -900000, 0)</posFromRimworld>
		
		<typeTag>Planet</typeTag>
		<gravityWellExitElevation>1000</gravityWellExitElevation>
		<gravityWellRadius>200</gravityWellRadius>
	</LayeredAtmosphereOrbit.PlanetDef>
	

	<LayeredAtmosphereOrbit.PlanetLayerGroupDef>
		<defName>SWCPPlanetLayerGroup_RhenVar</defName>
		<label>Rhen Var</label>
		<description>This place reminds me of you, Ulic...</description>
		<!-- <description>The foundational layer of pulverized rock and dust where ancient impacts scar the terrain. This is the airless ground that forms the outermost shell of the Luna. This stark surface is where sunlight meets shadow and where vast, barren plains stretch endlessly. It provides the base for all of the Luna's natural geography, from towering peaks of crater rims to deep, shadowed chasms.</description> -->
		<defaultPlanetLayer>SWCPPlanetLayer_RhenVar</defaultPlanetLayer>
		<viewGizmoTexPath>World/PlanetIcons/rhenvar</viewGizmoTexPath>
		<planet>SWCPPlanet_RhenVar</planet>
		
		<modExtensions>
			<li Class="LayeredAtmosphereOrbit.LayeredAtmosphereOrbitDefModExtension">
				<!-- <vacuum>1</vacuum> -->
				
				
				<onlyAllowWhitelistedFactions>true</onlyAllowWhitelistedFactions>
				<!-- <minFactionTechLevel>Spacer</minFactionTechLevel> -->
				<WhitelistFactionDef>
					<li>Insect</li>
					
					<li>guy762_KotORFaction_Civilians</li>
					
					<!-- <li MayRequire="guy762.KotORFactions">guy762_KotORFaction_Czerka</li> -->
					<!-- <li MayRequire="guy762.KotORFactions">guy762_KotORFaction_HuttCartel</li> -->
					<!-- <li MayRequire="guy762.KotORFactions">guy762_KotORFaction_ViciousHutts</li> -->
					
					<!-- <li MayRequire="SWCP.guy762.WarlordEmpire">guy762_SWWarlordsFaction_RebelCell</li> -->
					<!-- <li MayRequire="SWCP.guy762.WarlordEmpire">guy762_SWWarlordsFaction_PartisanCell</li> -->
					<!-- <li MayRequire="SWCP.guy762.WarlordEmpire">guy762_SWWarlordsFaction_ImpRemnant</li> -->
					<!-- <li MayRequire="SWCP.guy762.WarlordEmpire">guy762_SWWarlordsFaction_ZannConsortium</li> -->
				</WhitelistFactionDef>
				<BlacklistFactionDef>
					<li>Mechanoid</li>
					<li>TradersGuild</li>
					<li MayRequire="Ludeon.RimWorld.Royalty">Empire</li>
				</BlacklistFactionDef>
				<!-- <minArrivalFactionTechLevel>Spacer</minArrivalFactionTechLevel> -->
				<WhitelistArrivalFactionDef>
					<li>Insect</li>
				</WhitelistArrivalFactionDef>
				<BlacklistArrivalFactionDef>
					<li>Mechanoid</li>
					<li>TradersGuild</li>
					<li MayRequire="Ludeon.RimWorld.Royalty">Empire</li>
				</BlacklistArrivalFactionDef>
				
				
				<WhitelistGameConditionDef>
					<li>SolarFlare</li>
					<li>Planetkiller</li>
					<li>PsychicDroner</li>
					<li MayRequire="Ludeon.RimWorld.Royalty">SunBlocker</li>
					<li MayRequire="Ludeon.RimWorld.Royalty">PsychicSuppression</li>
					<li MayRequire="Ludeon.RimWorld.Royalty">EMIField</li>
					<li MayRequire="Ludeon.RimWorld.Anomaly">GrayPall</li>
					<li MayRequire="Ludeon.RimWorld.Anomaly">HateChantDrone</li>
					<li MayRequire="Ludeon.RimWorld.Anomaly">UnnaturalDarkness</li>
					<li MayRequire="MrHydralisk.AnomaliesExpected">AE_TemperatureDrop</li>
					<li MayRequire="MrHydralisk.AnomaliesExpected">AE_UnnaturalCold</li>
					<li MayRequire="MrHydralisk.AnomaliesExpected">AE_UnnaturalTemperature</li>
				</WhitelistGameConditionDef>
				<WhitelistIncidentDef>
					<li>Disease_OrganDecay</li>
					<li>RefugeePodCrash</li>
					<li>PsychicEmanatorShipPartCrash</li>
					<li>SolarFlare</li>
					<li>OrbitalDebris</li>
				</WhitelistIncidentDef>
			</li>
		</modExtensions>
	</LayeredAtmosphereOrbit.PlanetLayerGroupDef>
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	<!-- /////////////////////////////// Rhen Var Surface /////////////////////////////// -->
	
	
	<PlanetLayerSettingsDef>
		<defName>SWCPPlanetLayer_RhenVar</defName> <!-- "defName of PlanetLayerDef, PlanetLayerSettingsDef and ScenPartDef must be same" -->
		<label>Rhen Var surface</label>
		<settings>
			<!-- <origin>(-300,25,0)</origin> -->
			<radius>80</radius>
			<subdivisions>8</subdivisions> <!-- tile density, affects performance, DO NOT raise above 10 -->
			<useSurfaceViewAngle>true</useSurfaceViewAngle>
			<!-- <extraCameraAltitude>-90</extraCameraAltitude> -->
			
			<!-- <backgroundWorldCameraOffset>16</backgroundWorldCameraOffset> -->
			<!-- <backgroundWorldCameraParallaxDistancePer100Cells>0.25</backgroundWorldCameraParallaxDistancePer100Cells> -->
		</settings>
	</PlanetLayerSettingsDef>
	
	<ScenPartDef>
		<defName>SWCPPlanetLayer_RhenVar</defName> <!-- "defName of PlanetLayerDef, PlanetLayerSettingsDef and ScenPartDef must be same" -->
		<label>Rhen Var surface layer type</label>
		<scenPartClass>ScenPart_PlanetLayerFixed</scenPartClass>
		<category>Fixed</category>
		<summaryPriority>100</summaryPriority>
		<canBeRandomlyAdded>false</canBeRandomlyAdded>
		<canBePlayerAddedRemoved>false</canBePlayerAddedRemoved>
	</ScenPartDef>
	
	<PlanetLayerDef>
		<defName>SWCPPlanetLayer_RhenVar</defName> <!-- "defName of PlanetLayerDef, PlanetLayerSettingsDef and ScenPartDef must be same" -->
		<label>Rhen Var</label>
		<viewGizmoTooltip>View locations that are on Rhen Var's surface.</viewGizmoTooltip>
		<viewGizmoTexPath>World/PlanetIcons/rhenvar</viewGizmoTexPath>
		<defaultBiome>SWCPBiome_RhenVarGlacialWastes</defaultBiome>
		<!-- <backgroundBiome>SWCPBiome_Ocean</backgroundBiome> -->
		<backgroundBiome>Ocean</backgroundBiome>
		
		<layerType>SurfaceLayer</layerType>
		<tileType>SurfaceTile</tileType>
		<elevationString>{0}m</elevationString>
		<gerundLabel>on the</gerundLabel>
		<onlyAllowWhitelistedIncidents>true</onlyAllowWhitelistedIncidents>
		<onlyAllowWhitelistedBiomes>true</onlyAllowWhitelistedBiomes>
		<onlyAllowWhitelistedGameConditions>true</onlyAllowWhitelistedGameConditions>
		<onlyAllowWhitelistedQuests>true</onlyAllowWhitelistedQuests>
		
		<worldGenSteps>
			<li>Terrain</li>
			<li>Lakes</li>
			<!-- <li>Rivers</li> -->
			<li>Mutators</li>
			<li MayRequire="Ludeon.RimWorld.Odyssey">Landmarks</li>
			<li>AncientSites</li>
			<!-- <li>AncientRoads</li> -->
			<!-- <li MayRequire="Ludeon.RimWorld.Biotech">Pollution</li> -->
			<li>Factions</li>
			<!-- <li>Roads</li> -->
			<li>Features</li>
		</worldGenSteps>
		
		<settlementsPer100kTiles>45~55</settlementsPer100kTiles> <!-- 75~85 is default -->
		<generatedLocationFactor>1</generatedLocationFactor>
		
		<worldDrawLayers>
		  <li>WorldDrawLayer_CurrentMapTile</li>
		  <li>WorldDrawLayer_SelectedTile</li>
		  <li>WorldDrawLayer_SettleTile</li>
		  <li>WorldDrawLayer_MouseTile</li>
		  <li>WorldDrawLayer_ClosestTile</li>
		  <li>LayeredAtmosphereOrbit.WorldDrawLayer_UngeneratedPlanetPartsBackgroundBiome</li>
		  <li>WorldDrawLayer_WorldObjects_Expandable</li>
		  <li>WorldDrawLayer_WorldObjects_NonExpandable</li>
		  <li>WorldDrawLayer_DebugNoise</li>
		  <li>WorldDrawLayer_Landmarks</li>
		  <li>WorldDrawLayer_Glow</li>
		  <li>WorldDrawLayer_Hills</li>
		  <li MayRequire="Ludeon.RimWorld.Biotech">WorldDrawLayer_Pollution</li>
		  <li>WorldDrawLayer_Rivers</li>
		  <li>WorldDrawLayer_Roads</li>
		  <li>WorldDrawLayer_Terrain</li>
		  <li>WorldDrawLayer_Clouds</li>
		</worldDrawLayers>
		
		<worldTabs>
			<li>WITab_Terrain</li>
			<li>WITab_Planet</li>
		</worldTabs>
		<modExtensions>
			<li Class="LayeredAtmosphereOrbit.LayeredAtmosphereOrbitDefModExtension">
				<isReplaceConnections>true</isReplaceConnections>
				<isOptionToAutoAdd>true</isOptionToAutoAdd>
				<isSurface>true</isSurface>
				<elevation>0</elevation>
				<planetLayerGroup>SWCPPlanetLayerGroup_RhenVar</planetLayerGroup>
				<multScatterLumpsMineable>0.4</multScatterLumpsMineable>
				<IncidentChanceMultipliers>
					<OrbitalDebris>5</OrbitalDebris>
					<SolarFlare>2.3</SolarFlare>
					<MeteoriteImpact>4</MeteoriteImpact>
					<Infestation>1.5</Infestation>
				</IncidentChanceMultipliers>
				
				<WhitelistBiomeDef>
					<li>Ocean</li>
					<li>Lake</li>
					
					<li>SeaIce</li>
					<li>SWCPBiome_RhenVarGlacialPeaks</li>
					<li>SWCPBiome_RhenVarGlacialHighland</li>
					<li>SWCPBiome_RhenVarGlacialWastes</li>
				</WhitelistBiomeDef>
				<tempOffest>-50</tempOffest>
				
				<WhitelistIncidentDef>
					<li>Infestation</li>
					<li>DeepDrillInfestation</li>
					<li>Ambush</li>
					<li>CaravanMeeting</li>
					<li>CaravanDemand</li>
					<li>WandererJoin</li>
					<li>RansomDemand</li>
					<li>VisitorGroup</li>
					<li>TravelerGroup</li>
					<li>RaidFriendly</li>
					<li>GameEndedWanderersJoin</li>
					<li>DefoliatorShipPartCrash</li>
					<li MayRequire="Ludeon.RimWorld.Royalty">WandererJoinAbasia</li>
					<li MayRequire="Ludeon.RimWorld.Royalty">Disease_Abasia</li>
					<li MayRequire="Ludeon.RimWorld.Royalty">Disease_BloodRot</li>
					<li>GiveQuest_MechanoidSignal</li>
				</WhitelistIncidentDef>
				<WhitelistQuestScriptDef>
					<li>ThreatReward_Raid_Joiner</li>
					<li>DelayedRewardDropPods</li>
					<li>OpportunitySite_ItemStash</li>
					<li>LongRangeMineralScannerLump</li>
					<li>OpportunitySite_PrisonerWillingToJoin</li>
					<li>TradeRequest</li>
					<li>RefugeePodCrash</li>
					<li>OpportunitySite_AncientMercenaries</li>
					<li>Opportunity_AncientStructureLaunchSite</li>
					<li>Opportunity_AncientStructureGarrison</li>
					<li>Opportunity_AncientStructureChemfuelRefinery</li>
					<li>Opportunity_AncientStructureWarehouse</li>
					<li>Opportunity_AncientInfestedSettlement</li>
					<li>OpportunitySite_BanditCamp_Giver</li>
					<li>MechanoidSignal</li>
					<li>GravEngine</li>
					<li>Gravcore_MechanoidRelay</li>
					<li>Gravcore_InsectLair</li>
					<li>Gravcore_AncientReactor</li>
					<li>Gravcore_AncientStockpile</li>
					<li>Gravcore_CrashedMechanoidPlatform</li>
					<li>GravshipWreckage</li>
					<li>OpportunitySite_ItemStash_Giver</li>
					<li>SurveySite</li>
				</WhitelistQuestScriptDef>
			</li>
		</modExtensions>
	</PlanetLayerDef>
	
	
	
	
	
	
	
	
	
	
	
	<!-- /////////////////////////////// Rhen Var Orbit /////////////////////////////// -->	
	
	<GeneratedLocationDef>
