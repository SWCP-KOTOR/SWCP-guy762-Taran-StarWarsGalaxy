<?xml version="1.0" encoding="utf-8" ?>
<Defs>



  <!-- ================ Rhen Var granite ================ -->

  <ThingDef ParentName="UglyRockBase" Name="SWCPStone_RhenVarGranite">
    <defName>SWCPStone_RhenVarGranite</defName>
    <label>Rhen Varian granite</label>
    <description>A very hard igneous rock.</description>
    <graphicData>
      <color>(95,95,105)</color>
    </graphicData>
    <statBases>
      <MaxHitPoints>900</MaxHitPoints>
    </statBases>
    <building>
      <biomeSpecific>true</biomeSpecific>
	  <mineableThing>SWCPStoneChunk_RhenVarGranite</mineableThing>
      <mineableDropChance>0.25</mineableDropChance>
      <smoothedThing>SWCPStoneSmoothed_RhenVarGranite</smoothedThing>
    </building>
  </ThingDef>

  <ThingDef ParentName="SWCPStone_RhenVarGranite">
    <defName>SWCPStoneSmoothed_RhenVarGranite</defName>
    <label>smoothed Rhen Varian granite</label>
    <description>A very hard igneous rock.</description>
    <uiIconPath>Things/Building/Linked/WallSmooth_MenuIcon</uiIconPath>
    <graphicData>
      <texPath>Things/Building/Linked/RockSmooth_Atlas</texPath>
    </graphicData>
    <statBases>
      <Beauty>1</Beauty>
      <MarketValue>7</MarketValue>
    </statBases>
    <building>
      <isNaturalRock>false</isNaturalRock>
      <canBuildNonEdificesUnder>true</canBuildNonEdificesUnder>
      <artificialForMeditationPurposes>false</artificialForMeditationPurposes>
      <smoothedThing />
      <paintable>true</paintable>
    </building>
    <saveCompressible>false</saveCompressible>
    <repairEffect>Repair</repairEffect>
  </ThingDef>
  
  <ThingDef ParentName="ChunkRockBase">
    <defName>SWCPStoneChunk_RhenVarGranite</defName>
    <label>Rhen Varian granite chunk</label>
    <graphicData>
      <color>(95,95,105)</color>
    </graphicData>
    <statBases>
      <Mass>22</Mass>
    </statBases>
    <soundDrop>ChunkRock_Drop</soundDrop>
    <butcherProducts>
      <SWCPStoneBlocks_RhenVarGranite>20</SWCPStoneBlocks_RhenVarGranite>
    </butcherProducts>
  </ThingDef>

  <ThingDef ParentName="StoneBlocksBase">
    <defName>SWCPStoneBlocks_RhenVarGranite</defName>
    <label>Rhen Varian granite blocks</label>
    <description>Blocks of solid Rhen Varian granite.</description>
    <graphicData>
      <color>(95,95,105)</color>
    </graphicData>
    <statBases>
      <Mass>1.25</Mass>
      <SharpDamageMultiplier>0.65</SharpDamageMultiplier>
    </statBases>
    <stuffProps>
      <color>(95,95,105)</color>
      <soundImpactBullet>BulletImpact_Ground</soundImpactBullet>
      <soundMeleeHitSharp>MeleeHit_Stone</soundMeleeHitSharp>
      <soundMeleeHitBlunt>MeleeHit_Stone</soundMeleeHitBlunt>
      <soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Stone</soundImpactMelee>
      <stuffAdjective>granite</stuffAdjective>
      <statFactors>
        <MaxHitPoints>1.7</MaxHitPoints>
      </statFactors>
      <canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
    </stuffProps>
  </ThingDef>

  <RecipeDef ParentName="MakeStoneBlocksBase">
    <defName>SWCPRecipe_BlocksRhenVarGranite</defName>
    <label>make Rhen Varian granite blocks</label>
    <description>Cuts Rhen Varian granite chunks into usable blocks.</description>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>SWCPStoneChunk_RhenVarGranite</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>SWCPStoneChunk_RhenVarGranite</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <SWCPStoneBlocks_RhenVarGranite>20</SWCPStoneBlocks_RhenVarGranite>
    </products>
  </RecipeDef>
  
  
  <TerrainDef ParentName="TileStoneBase">
    <defName>SWCPTerrain_StoneTile_RhenVarGranite</defName>
    <label>Rhen Varian granite tile</label>
    <color>(95,95,105)</color>
    <costList>
      <SWCPStoneBlocks_RhenVarGranite>4</SWCPStoneBlocks_RhenVarGranite>
    </costList>
  </TerrainDef>
  
  
  <TerrainDef ParentName="FlagstoneBase">
    <defName>SWCPTerrain_Flagstone_RhenVarGranite</defName>
    <label>Rhen Varian granite flagstone</label>
    <color>(95,95,105)</color>
    <costList>
      <SWCPStoneBlocks_RhenVarGranite>4</SWCPStoneBlocks_RhenVarGranite>
    </costList>
  </TerrainDef>
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
