  <!-- ================ blue ice ================ -->
  
  <ThingDef ParentName="RockBase" Name="SWCPStone_RhenVarBlueIce">
		<defName>SWCPStone_RhenVarBlueIce</defName>
		<label>blue ice</label>
		<description>Solid blue glacial ice. It can be mined through with relative ease.</description>
		<uiIconPath>Things/Building/Linked/SolidIceWall_MenuIcon</uiIconPath>
		<graphicData>
		  <texPath>Things/Building/Linked/SolidIceWall_Atlas</texPath>
		  <color>(165,205,240)</color>
		  <linkFlags Inherit="false">
			<li>SolidIce</li>
			<li>MapEdge</li>
		  </linkFlags>
		</graphicData>
		<statBases>
		  <Flammability>0</Flammability>
		  <Beauty>1</Beauty>
		  <MaxHitPoints>240</MaxHitPoints>
		</statBases>
		<building>
		  <smoothedThing>SWCPStone_RhenVarBlueSmoothedIce</smoothedThing>
		  <mineableYieldWasteable>false</mineableYieldWasteable>
		  <biomeSpecific>true</biomeSpecific>
		  <mineableScatterLumpSizeRange>12~32</mineableScatterLumpSizeRange>
		  <mineablePreventMeteorite>true</mineablePreventMeteorite>
		  <naturalTerrain>SWCPTerrain_RhenVarBlueIce</naturalTerrain>
		  <leaveTerrain>SWCPTerrain_RhenVarBlueIce</leaveTerrain>
		</building>
		<filthLeaving>Filth_ChippedIce</filthLeaving>
	</ThingDef>

	<ThingDef ParentName="SWCPStone_RhenVarBlueIce">
		<defName>SWCPStone_RhenVarBlueSmoothedIce</defName>
		<label>smoothed blue ice</label>
		<description>Solid blue glacial ice. It can be mined through with relative ease. The polished surface glistens a bright blue.</description>
		<uiIconPath>Things/Building/Linked/SmoothedIce_MenuIcon</uiIconPath>
		<graphicData>
		  <texPath>Things/Building/Linked/SmoothedIce_Atlas</texPath>
		</graphicData>
		<statBases>
		  <Beauty>3</Beauty>
		</statBases>
		<building>
		  <isNaturalRock>false</isNaturalRock>
		  <canBuildNonEdificesUnder>true</canBuildNonEdificesUnder>
		  <artificialForMeditationPurposes>false</artificialForMeditationPurposes>
		  <smoothedThing />
		</building>
		<saveCompressible>false</saveCompressible>
		<repairEffect>Repair</repairEffect>
	</ThingDef>
	
	<TerrainDef ParentName="NaturalTerrainBase">
		<defName>SWCPTerrain_RhenVarBlueIce</defName>
		<label>blue ice</label>
		<texturePath>BiomeTerrain/RhenVarBlueIce</texturePath>
		<edgeType>FadeRough</edgeType>
		<renderPrecedence>350</renderPrecedence>
		<pathCost>14</pathCost>
		<statBases>
		  <Beauty>0</Beauty>
		  <BeautyOutdoors>3</BeautyOutdoors>
		</statBases>
		<scatterType>SoftGray</scatterType>
		<tags>
		  <li>SWCPRhenVarTerrain_Ice</li>
		</tags>
		<affordances>
		  <li>Light</li>
		  <li>Medium</li>
		  <li>Heavy</li>
		  <li>Diggable</li>
		</affordances>
		<generatedFilth>Filth_ChippedIce</generatedFilth>
		<fertility>0.00</fertility>
		<takeFootprints>True</takeFootprints>
		<pollutedTexturePath>Terrain/Surfaces/IcePolluted</pollutedTexturePath>
		<pollutionOverlayTexturePath>Terrain/Surfaces/PollutionIce</pollutionOverlayTexturePath>
		<pollutionColor>(1, 1, 1, 1)</pollutionColor>
		<pollutionCloudColor>(1, 1, 1, 0.66)</pollutionCloudColor>
		<canEverTerraform>false</canEverTerraform>
	</TerrainDef>

  
</Defs>
