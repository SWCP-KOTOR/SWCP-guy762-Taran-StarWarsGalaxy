	<BiomeDef ParentName="SpaceBiome">
		<defName>SWCPBiome_Orbit</defName>
		<label>orbit</label>
		<description>Empty space a few hundred kilometers above the surface of the world. May contain Mynocks.</description>

		<wildAnimals>
			<Mynock MayRequire="Mlie.StarWarsAnimalCollection">0.1</Mynock>
		</wildAnimals>
	</BiomeDef>
	
	
	
	
	
	
	
	
	
	
	
	
	
	<BiomeDef Name="SWCPBiome_Ocean">
		<defName>SWCPBiome_Ocean</defName>
		<label>ocean</label>
		<description>Open ocean. Great for fish. Not so great for you.</description>
		<workerClass>BiomeWorker_Ocean</workerClass>
		<isWaterBiome>true</isWaterBiome>
		<canBuildBase>false</canBuildBase>
		<allowRoads>false</allowRoads>
		<allowRivers>false</allowRivers>
		<hasVirtualPlants>false</hasVirtualPlants>
		<texture>World/Biomes/OrdMantellOcean</texture>
		<impassable>true</impassable>
		<isBackgroundBiome>true</isBackgroundBiome>
		
		<!-- <layerWhitelist> -->
			<!-- <li>SWCPPlanetLayer_OrdMantell</li> -->
		<!-- </layerWhitelist> -->
	</BiomeDef>

	<BiomeDef Name="SWCPBiome_Lake">
		<defName>SWCPBiome_Lake</defName>
		<label>lake</label>
		<description>A large lake. Beautiful to live next to. Not so beautiful to live in.</description>
		<workerClass>BiomeWorker_Ocean</workerClass>
		<isWaterBiome>true</isWaterBiome>
		<canBuildBase>false</canBuildBase>
		<allowRoads>false</allowRoads>
		<allowRivers>false</allowRivers>
		<hasVirtualPlants>false</hasVirtualPlants>
		<texture>World/Biomes/OrdMantellOcean</texture>
		<impassable>true</impassable>
		<isBackgroundBiome>true</isBackgroundBiome>
		
		<!-- <layerWhitelist> -->
			<!-- <li>SWCPPlanetLayer_OrdMantell</li> -->
		<!-- </layerWhitelist> -->
	</BiomeDef>
	
	
	
	
	
	
	<BiomeDef Name="SWCPBiome_LavaOcean">
		<defName>SWCPBiome_LavaOcean</defName>
		<label>lava ocean</label>
		<description>An ocean of lava. Not so great for fish. Not so great for you either.</description>
		<workerClass>BiomeWorker_Ocean</workerClass>
		<isWaterBiome>true</isWaterBiome>
		<canBuildBase>false</canBuildBase>
		<allowRoads>false</allowRoads>
		<allowRivers>false</allowRivers>
		<hasVirtualPlants>false</hasVirtualPlants>
		<texture>World/Biomes/LavaOcean</texture>
		<impassable>true</impassable>
		<isBackgroundBiome>true</isBackgroundBiome>
	</BiomeDef>
	
