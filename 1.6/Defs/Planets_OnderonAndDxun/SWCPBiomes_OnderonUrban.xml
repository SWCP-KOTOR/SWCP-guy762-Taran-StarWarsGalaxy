		<defName>SWCPBiomeNamer_OnderonUrban</defName>
		<include>
		  <li>WorldFeatureNamerCommon</li>
		</include>
		<rulePack>
		  <rulesStrings>
			<li>r_name(p=0.2)->[narrative_name] [terrain_word]</li>
