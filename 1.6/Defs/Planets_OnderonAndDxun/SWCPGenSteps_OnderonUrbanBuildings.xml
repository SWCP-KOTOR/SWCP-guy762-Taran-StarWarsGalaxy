		<roomDefs>
			<!-- <SWCPRoomLayout_NPCReactor>1</SWCPRoomLayout_NPCReactor> -->
			
			<SWCPRoomLayout_UrbanKitchen>3</SWCPRoomLayout_UrbanKitchen>
			<SWCPRoomLayout_UrbanDiningHall>3</SWCPRoomLayout_UrbanDiningHall>
			
			<SWCPRoomLayout_UrbanLivingArea>2</SWCPRoomLayout_UrbanLivingArea>
