		<texture>World/Biomes/DxunSwamp</texture>
		<forageability>1</forageability>
		<foragedFood>RawBerries</foragedFood>
		<wildPlantRegrowDays>13</wildPlantRegrowDays>
		
		<maxFishPopulation>780</maxFishPopulation>
