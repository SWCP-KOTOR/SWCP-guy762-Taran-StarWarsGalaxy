		<workerClass>BiomeWorker_Ocean</workerClass>
		<animalDensity>0.5</animalDensity>
		<plantDensity>0.99</plantDensity>
		
		<settlementSelectionWeight>0</settlementSelectionWeight>
		<campSelectionWeight>0.1</campSelectionWeight>
