	<TerrainDef ParentName="NaturalTerrainBase">
		<defName>SWCPTerrain_DxunGrasslandSoil</defName>
		<label>grassy soil</label>
		<texturePath>BiomeTerrain/DxunGrasslandSoil</texturePath>
		<pollutedTexturePath>Terrain/Surfaces/SoilPolluted</pollutedTexturePath>
		<edgeType>FadeRough</edgeType>
		<categoryType>Soil</categoryType>
		<renderPrecedence>340</renderPrecedence>
		<pathCost>2</pathCost>
		<statBases>
		  <Beauty>-3</Beauty>
		  <BeautyOutdoors>0</BeautyOutdoors>
		  <Cleanliness>-1</Cleanliness>
		</statBases>
		<scatterType>Rocky</scatterType>
		<affordances>
		  <li>Light</li>
		  <li>Medium</li>
		  <li>Heavy</li>
		  <li>GrowSoil</li>
		  <li>Diggable</li>
		</affordances>
		<generatedFilth>Filth_Dirt</generatedFilth>
		<fertility>1.0</fertility>
		<takeFootprints>True</takeFootprints>
		<tools>
		  <li>
			<label>dirt</label>
			<capacities>
			  <li>KickMaterialInEyes</li>
			</capacities>
			<hediff>DirtInEyes</hediff>
			<cooldownTime>1.5</cooldownTime>
		  </li>
		</tools>
		<tags>
			<li>SWCPDxunTerrain_Soil</li>
		</tags>
	</TerrainDef>
	
	
