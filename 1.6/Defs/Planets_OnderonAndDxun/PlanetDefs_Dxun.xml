<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	
	<LayeredAtmosphereOrbit.PlanetDef>
		<defName>SWCPPlanet_Dxun</defName>
		<label>Dxun</label>
		<description>Much is buried here, and there is much that should remain buried.\n\nDistance to Rimworld: 375000 km.\nDiameter: 100% of Rimworld.\n\nGravity well elevation: 1000 km.</description>
		<viewGizmoTexPath>World/PlanetIcons/dxun</viewGizmoTexPath>
		
		<posFromRimworld>(-2501000, -2501000, 0)</posFromRimworld>
		
		<typeTag>Moon</typeTag>
		<gravityWellExitElevation>300</gravityWellExitElevation>
		<gravityWellRadius>75</gravityWellRadius>
	</LayeredAtmosphereOrbit.PlanetDef>
	
	<LayeredAtmosphereOrbit.PlanetLayerGroupDef>
		<defName>SWCPPlanetLayerGroup_Dxun</defName>
		<label>Dxun</label>
		<description>Much is buried here, and there is much that should remain buried.</description>
