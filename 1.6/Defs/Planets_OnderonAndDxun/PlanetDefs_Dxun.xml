			<li MayRequire="Ludeon.RimWorld.Odyssey">Landmarks</li>
			<li>AncientSites</li>
			<li>AncientRoads</li>
			<!-- <li MayRequire="Ludeon.RimWorld.Biotech">Pollution</li> -->
