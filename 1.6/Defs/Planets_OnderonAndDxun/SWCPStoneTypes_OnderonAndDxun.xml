<?xml version="1.0" encoding="utf-8" ?>
<Defs>



  <!-- ================ Onderonian marble ================ -->

  <ThingDef ParentName="UglyRockBase" Name="SWCPStone_OnderonMarble">
    <defName>SWCPStone_OnderonMarble</defName>
    <label>Onderonian marble</label>
    <description>A soft metamorphic rock.</description>
    <graphicData>
      <color>(205,185,145)</color>
    </graphicData>
    <statBases>
      <MaxHitPoints>450</MaxHitPoints>
      <Beauty>-1</Beauty>
    </statBases>
    <building>
      <biomeSpecific>true</biomeSpecific>
	  <mineableThing>SWCPStoneChunk_OnderonMarble</mineableThing>
      <mineableDropChance>0.25</mineableDropChance>
      <smoothedThing>SWCPStoneSmoothed_OnderonMarble</smoothedThing>
    </building>
  </ThingDef>

  <ThingDef ParentName="SWCPStone_OnderonMarble">
    <defName>SWCPStoneSmoothed_OnderonMarble</defName>
    <label>smoothed Onderonian marble</label>
    <description>A soft metamorphic rock. This semi-transparent rock almost appears to glow with its own inner light.</description>
    <uiIconPath>Things/Building/Linked/WallSmooth_MenuIcon</uiIconPath>
    <graphicData>
      <texPath>Things/Building/Linked/RockSmooth_Atlas</texPath>
    </graphicData>
    <statBases>
      <Beauty>2</Beauty>
      <MarketValue>7</MarketValue>
    </statBases>
    <building>
      <isNaturalRock>false</isNaturalRock>
      <canBuildNonEdificesUnder>true</canBuildNonEdificesUnder>
      <artificialForMeditationPurposes>false</artificialForMeditationPurposes>
      <smoothedThing />
      <paintable>true</paintable>
    </building>
    <saveCompressible>false</saveCompressible>
    <repairEffect>Repair</repairEffect>
  </ThingDef>
  
  <ThingDef ParentName="ChunkRockBase">
    <defName>SWCPStoneChunk_OnderonMarble</defName>
    <label>Onderonian marble chunk</label>
    <graphicData>
      <color>(205,185,145)</color>
    </graphicData>
    <statBases>
      <Mass>25</Mass>
    </statBases>
    <soundDrop>ChunkRock_Drop</soundDrop>
    <butcherProducts>
      <SWCPStoneBlocks_OnderonMarble>20</SWCPStoneBlocks_OnderonMarble>
    </butcherProducts>
  </ThingDef>

  <ThingDef ParentName="StoneBlocksBase">
    <defName>SWCPStoneBlocks_OnderonMarble</defName>
    <label>Onderonian marble blocks</label>
    <description>Blocks of solid Onderonian marble. Marble is a soft, beautiful stone, known for being easy to sculpt.</description>
    <graphicData>
      <color>(205,185,145)</color>
    </graphicData>
    <statBases>
      <Mass>1.25</Mass>
    </statBases>
    <stuffProps>
      <color>(205,185,145)</color>
      <soundImpactBullet>BulletImpact_Ground</soundImpactBullet>
      <soundMeleeHitSharp>MeleeHit_Stone</soundMeleeHitSharp>
      <soundMeleeHitBlunt>MeleeHit_Stone</soundMeleeHitBlunt>
      <soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Stone</soundImpactMelee>
      <stuffAdjective>marble</stuffAdjective>
      <statFactors>
        <Beauty>1.35</Beauty>
        <MaxHitPoints>1.2</MaxHitPoints>
        <WorkToBuild>5.5</WorkToBuild>
        <WorkToMake>1.15</WorkToMake>
      </statFactors>
      <statOffsets>
        <Beauty>1</Beauty>
      </statOffsets>
      <canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
    </stuffProps>
  </ThingDef>

  <RecipeDef ParentName="MakeStoneBlocksBase">
    <defName>SWCPRecipe_BlocksOnderonMarble</defName>
    <label>make Onderonian marble blocks</label>
    <description>Cuts Onderonian marble chunks into usable blocks.</description>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>SWCPStoneChunk_OnderonMarble</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>SWCPStoneChunk_OnderonMarble</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <SWCPStoneBlocks_OnderonMarble>20</SWCPStoneBlocks_OnderonMarble>
    </products>
  </RecipeDef>
  
  
  <TerrainDef ParentName="TileStoneBase">
    <defName>SWCPTerrain_StoneTile_OnderonMarble</defName>
    <label>Onderonian marble tile</label>
    <color>(205,185,145)</color>
    <costList>
      <SWCPStoneBlocks_OnderonMarble>4</SWCPStoneBlocks_OnderonMarble>
    </costList>
  </TerrainDef>
  
  
  <TerrainDef ParentName="FlagstoneBase">
    <defName>SWCPTerrain_Flagstone_OnderonMarble</defName>
    <label>Onderonian marble flagstone</label>
    <color>(205,185,145)</color>
    <costList>
      <SWCPStoneBlocks_OnderonMarble>4</SWCPStoneBlocks_OnderonMarble>
    </costList>
  </TerrainDef>
  
  
  
  
  
  
  
  
  
  
  
  
  
