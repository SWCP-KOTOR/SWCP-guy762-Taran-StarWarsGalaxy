<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	
	<ThingDef ParentName="BuildingBase">
		<defName>SWCPBuilding_NPCPowerGenerator</defName>
		<label>fixed municipal reactor</label>
		<description>Produces large amounts of power by igniting motes of the volatile substance Rhydonium (extracted from Rhydonium fuel). Units like these are commonly employed in small transport ships, military bases, and some municipal power plants.</description>
		<!--description>Produces large amounts of power by igniting motes of the volatile substance Rhydonium (extracted from Rhydonium fuel). This is essentially a scaled-down version of the Kesselii-Adec Hyperdrive Fusion Reactor invented more than a century before the Great Hyperspace War. Units like these are commonly employed in small transport ships, military bases, and some municipal power plants.</description-->
		<thingClass>Building</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Buildings/NPCPowerGenerator/NPCPowerGenerator</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(4,4)</drawSize>
			<drawOffset>(0,0,0.125)</drawOffset>
			<shadowData>
				<volume>(2.5, 0.5, 2)</volume>
				<offset>(0,0,-0.25)</offset>
			</shadowData>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<passability>Impassable</passability>
		<!-- <passability>PassThroughOnly</passability> -->
		<!-- <pathCost>50</pathCost> -->
		<blockWind>true</blockWind>
		<fillPercent>1.0</fillPercent>
		<rotatable>true</rotatable>
		<statBases>
			<MaxHitPoints>1000</MaxHitPoints>
			<!-- <WorkToBuild>7000</WorkToBuild> -->
			<Flammability>2.0</Flammability>
			<Beauty>-10</Beauty>
		</statBases>
		
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		
		<tickerType>Normal</tickerType>
		<canOverlapZones>false</canOverlapZones>
		<size>(3,3)</size>
		<building>
			<destroySound>BuildingDestroyed_Metal_Medium</destroySound>
		</building>
		<!-- <costList> -->
			<!-- <KOTOR_AlloyDurasteel>200</KOTOR_AlloyDurasteel> -->
			<!-- <KOTOR_IngotCortosis>30</KOTOR_IngotCortosis> -->
			<!-- <ComponentSpacer>3</ComponentSpacer> -->
			<!-- <KOTOR_UltraComponent>1</KOTOR_UltraComponent> -->
		<!-- </costList> -->
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerPlant</compClass>
				<basePowerConsumption>-5000</basePowerConsumption>
				<transmitsPower>true</transmitsPower>
				<soundAmbientProducingPower>kotorsound_building_PowerGenerator</soundAmbientProducingPower>
				<soundPowerOn>kotorsound_starfighter_activate</soundPowerOn>
				<soundPowerOff>kotorsound_starfighter_deactivate</soundPowerOff>
			</li>
			<li Class="CompProperties_Flickable" />
			<!-- <li Class="CompProperties_Refuelable"> -->
				<!-- <fuelConsumptionRate>1.5</fuelConsumptionRate> -->
				<!-- <fuelCapacity>100.0</fuelCapacity> -->
				<!-- <fuelFilter> -->
					<!-- <thingDefs> -->
						<!-- <li>KOTOR_Rhydonium</li> -->
					<!-- </thingDefs> -->
				<!-- </fuelFilter> -->
				<!-- <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle> -->
			<!-- </li> -->
			<li Class="CompProperties_Glower">
				<glowRadius>3</glowRadius>
				<glowColor>(255,70,0,0)</glowColor>
			</li>
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>15</heatPerSecond>
			</li>
			<!-- <li Class="CompProperties_Breakdownable"/> -->
			<li Class="CompProperties_Explosive">
				<explosiveRadius>7</explosiveRadius>
				<explosiveExpandPerFuel>1.25</explosiveExpandPerFuel>
				<explosiveDamageType>Flame</explosiveDamageType>
				<destroyThingOnExplosionSize>2</destroyThingOnExplosionSize>
				<startWickHitPointsPercent>0.333</startWickHitPointsPercent>
				<preExplosionSpawnThingDef>Filth_Fuel</preExplosionSpawnThingDef>
				<preExplosionSpawnChance>1</preExplosionSpawnChance>
				<wickTicks>70~150</wickTicks>
			</li>
		</comps>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		
		<designationCategory Inherit="False"/>        <!-- important to not be able to be built normally-->
		<!-- <designationCategory>KOTOR_BuildTab</designationCategory><uiOrder>9999</uiOrder> -->
		
		<!-- <constructEffect>ConstructMetal</constructEffect> -->
		<researchPrerequisites>
			<li>guy762_ResearchKotOR_uncraftable</li>
		</researchPrerequisites>
		<!-- <constructionSkillPrerequisite>14</constructionSkillPrerequisite> -->
		<tradeTags>
			<li>guy762TT_AllItemsSellable</li>
		</tradeTags>	
	</ThingDef>
	
	
	
	
	<ThingDef ParentName="BuildingBase">
		<defName>SWCPBuilding_NPCMoistureVaporator</defName>
		<label>fixed municipal moisture vaporator</label>
		<description>A large device capable of condensing atmospheric water molecules into drinkable water. These devices are frequently employed by settlers in arid, dry climates where water is not readily available. Due to the complex nature of the moisture collection process, these devices are fine-tuned to only work in dry climates and the moisture-sensitive instruments employed to collect water will be non-functional in any other environment.</description>
		<graphicData>
		  <texPath>Buildings/MoistureVaporators/moisturevaporator_2</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <drawSize>(3,3)</drawSize>
		  <drawOffset>(0,0,1)</drawOffset>
		  <color>(205,200,195)</color>         <!-- off-light-grey -->
		  
		  <shadowData>
			<volume>(0.58, 0.35, 0.25)</volume>
			<offset>(0,0,-0.1)</offset>
		  </shadowData>
		  <damageData>
			<rect>(0.2,0.2,0.6,0.6)</rect>
		  </damageData>
		</graphicData>
		
		<size>(1,1)</size>
		<uiIconScale>0.3</uiIconScale>
		
		<comps>
		  <li Class="CompProperties_Spawner"> <!-- WARNING: patch in AdditionalMods for DBH references this specific <li> !!! -->
			<requiresPower>false</requiresPower>
			<thingToSpawn>KotOR_water</thingToSpawn>
			<spawnCount>5</spawnCount>
			<spawnIntervalRange><min>450000</min><max>450000</max></spawnIntervalRange>
			<writeTimeLeftToSpawn>true</writeTimeLeftToSpawn>
			<showMessageIfOwned>true</showMessageIfOwned>
		  </li>
		  <li Class="CompProperties_Forbiddable"/>
		  <!-- <li Class="CompProperties_Power"> -->
			<!-- <compClass>CompPowerTrader</compClass> -->
			<!-- <basePowerConsumption>50</basePowerConsumption> -->
		  <!-- </li> -->
		  <li Class="CompProperties_Flickable"/>
		  <li>
			<compClass>CompColorable</compClass>
		  </li>
		  <!-- <li Class="CompProperties_TerrainPumpDry"> -->
			<!-- <soundWorking>MoisturePump_Ambience</soundWorking> -->
			<!-- <radius>6.9</radius> -->
			<!-- <daysToRadius>60</daysToRadius> -->
		  <!-- </li> -->
		</comps>
		
		<placeWorkers>
		  <li>PlaceWorker_NotUnderRoof</li>
		  <li>PlaceWorker_NeverAdjacentSameDef</li>
		</placeWorkers>
		<!-- <terrainAffordanceNeeded>guy762_TerrainAffordance_softsand</terrainAffordanceNeeded> -->
		<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
		
		<!-- <specialDisplayRadius>3</specialDisplayRadius> -->
		
		<tickerType>Normal</tickerType>
		<altitudeLayer>Building</altitudeLayer>
		<statBases>
		  <MarketValue>2000</MarketValue>
		  
		  <MaxHitPoints>50</MaxHitPoints>
		  <!-- <WorkToBuild>1500</WorkToBuild> -->
		  <Flammability>1.0</Flammability>
		  <Beauty>-25</Beauty>
		  <Mass>35</Mass>
		</statBases>
		<fillPercent>0.3</fillPercent>
		<canOverlapZones>false</canOverlapZones>
		<building>
		  <ai_chillDestination>false</ai_chillDestination>
		  <destroySound>BuildingDestroyed_Metal_Small</destroySound>
		  <allowAutoroof>false</allowAutoroof>
		  <minDistanceToSameTypeOfBuilding>3</minDistanceToSameTypeOfBuilding>
		</building>
		<!-- <costList> -->
		  <!-- <Steel>75</Steel> -->
		  <!-- <ComponentIndustrial>4</ComponentIndustrial> -->
		  <!-- <ComponentSpacer>2</ComponentSpacer> -->
		<!-- </costList> -->
		
		<pathCost>30</pathCost>
		<passability>PassThroughOnly</passability>
		
		<designationCategory Inherit="False"/>        <!-- important to not be able to be built normally-->
		<!-- <designationCategory>KOTOR_BuildTab</designationCategory><uiOrder>9999</uiOrder> -->
		
		<rotatable>false</rotatable>
		<!-- <constructionSkillPrerequisite>6</constructionSkillPrerequisite> -->
		
		<researchPrerequisites>
			<li>guy762_ResearchKotOR_uncraftable</li>
		</researchPrerequisites>
		
		<!-- <minifiedDef>MinifiedThing</minifiedDef> -->
		<tradeability>All</tradeability>
		<tradeTags>
			<li>guy762TT_AllItemsSellable</li>
		</tradeTags>
	</ThingDef>
	
</Defs>