		<viewGizmoTexPath>World/PlanetIcons/ordmantell</viewGizmoTexPath>
		<defaultBiome>SWCPBiome_OrdMantellGrasslands</defaultBiome>
		<!-- <backgroundBiome>SWCPBiome_Ocean</backgroundBiome> -->
