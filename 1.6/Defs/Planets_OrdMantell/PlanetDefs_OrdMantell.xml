		<label>Ord Mantell orbit</label>
		<viewGizmoTooltip>View locations that are orbiting Ord Mantell.</viewGizmoTooltip>
		<viewGizmoTexPath>UI/Commands/ViewOrbit</viewGizmoTexPath>
		<elevationString>200km</elevationString>
