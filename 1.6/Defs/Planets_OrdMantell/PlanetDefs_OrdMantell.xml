			<li>AncientRoads</li>
			<li MayRequire="Ludeon.RimWorld.Biotech">Pollution</li>
			<li>Factions</li>
			<li>Roads</li>
			<li>Features</li>
		</worldGenSteps>
		
		<settlementsPer100kTiles>75~85</settlementsPer100kTiles> <!-- 75~85 is default -->
