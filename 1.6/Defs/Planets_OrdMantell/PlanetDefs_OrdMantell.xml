<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	
	<LayeredAtmosphereOrbit.PlanetDef>
		<defName>SWCPPlanet_OrdMantell</defName>
		<label>Ord Mantell</label>
		<description>I've been monitoring you, Captain Rendar...\n\nDistance to Rimworld: 375000 km.\nDiameter: 100% of Rimworld.\n\nGravity well elevation: 1000 km.</description>
		<viewGizmoTexPath>World/PlanetIcons/ordmantell</viewGizmoTexPath>
		
		<posFromRimworld>(-1000000, -1000000, 0)</posFromRimworld>
		
		<typeTag>Planet</typeTag>
		<gravityWellExitElevation>1000</gravityWellExitElevation>
		<gravityWellRadius>200</gravityWellRadius>
	</LayeredAtmosphereOrbit.PlanetDef>
	

	<LayeredAtmosphereOrbit.PlanetLayerGroupDef>
		<defName>SWCPPlanetLayerGroup_OrdMantell</defName>
		<label>Ord Mantell</label>
		<description>I've been monitoring you, Captain Rendar...</description>
