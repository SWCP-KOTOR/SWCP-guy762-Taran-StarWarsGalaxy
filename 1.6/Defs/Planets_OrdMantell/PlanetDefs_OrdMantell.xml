					<li>Disease_OrganDecay</li>
					<li>RefugeePodCrash</li>
					<li>PsychicEmanatorShipPartCrash</li>
					<li>SolarFlare</li>
					<li>OrbitalDebris</li>
				</WhitelistIncidentDef>
			</li>
		</modExtensions>
	</LayeredAtmosphereOrbit.PlanetLayerGroupDef>
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	<!-- /////////////////////////////// Ord Mantell Surface /////////////////////////////// -->
	
	
	<PlanetLayerSettingsDef>
		<defName>SWCPPlanetLayer_OrdMantell</defName> <!-- "defName of PlanetLayerDef, PlanetLayerSettingsDef and ScenPartDef must be same" -->
		<label>Ord Mantell surface</label>
		<settings>
			<!-- <origin>(-300,25,0)</origin> -->
			<radius>100</radius>
			<subdivisions>10</subdivisions> <!-- tile density, affects performance, DO NOT raise above 10 -->
			<useSurfaceViewAngle>true</useSurfaceViewAngle>
			<!-- <extraCameraAltitude>-90</extraCameraAltitude> -->
			
			<!-- <backgroundWorldCameraOffset>16</backgroundWorldCameraOffset> -->
			<!-- <backgroundWorldCameraParallaxDistancePer100Cells>0.25</backgroundWorldCameraParallaxDistancePer100Cells> -->
		</settings>
	</PlanetLayerSettingsDef>
	
	<ScenPartDef>
		<defName>SWCPPlanetLayer_OrdMantell</defName> <!-- "defName of PlanetLayerDef, PlanetLayerSettingsDef and ScenPartDef must be same" -->
		<label>Ord Mantell surface layer type</label>
		<scenPartClass>ScenPart_PlanetLayerFixed</scenPartClass>
		<category>Fixed</category>
		<summaryPriority>100</summaryPriority>
		<canBeRandomlyAdded>false</canBeRandomlyAdded>
		<canBePlayerAddedRemoved>false</canBePlayerAddedRemoved>
	</ScenPartDef>
	
	<PlanetLayerDef>
