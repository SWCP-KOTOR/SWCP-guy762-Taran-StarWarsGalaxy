	<PlanetLayerSettingsDef>
		<defName>SWCPPlanetLayer_OrdMantellOrbit</defName> <!-- "defName of PlanetLayerDef, PlanetLayerSettingsDef and ScenPartDef must be same" -->
		<label>Ord Mantell orbit</label>
		<settings>
			<radius>130</radius>
			<subdivisions>6</subdivisions> <!-- vanilla orbit has 5 -->
			<extraCameraAltitude>300</extraCameraAltitude>
			<backgroundWorldCameraOffset>160</backgroundWorldCameraOffset>
			<backgroundWorldCameraParallaxDistancePer100Cells>2.5</backgroundWorldCameraParallaxDistancePer100Cells>
			<useSurfaceViewAngle>true</useSurfaceViewAngle>
		</settings>
	</PlanetLayerSettingsDef>
	
	<ScenPartDef>
		<defName>SWCPPlanetLayer_OrdMantellOrbit</defName> <!-- "defName of PlanetLayerDef, PlanetLayerSettingsDef and ScenPartDef must be same" -->
		<label>Ord Mantell orbit layer type</label>
		<scenPartClass>ScenPart_PlanetLayerFixed</scenPartClass>
		<category>Fixed</category>
		<summaryPriority>100</summaryPriority>
		<canBeRandomlyAdded>false</canBeRandomlyAdded>
		<canBePlayerAddedRemoved>false</canBePlayerAddedRemoved>
	</ScenPartDef>
	
	<PlanetLayerDef ParentName="OrbitLayer">
