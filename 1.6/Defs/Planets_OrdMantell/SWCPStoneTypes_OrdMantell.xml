<?xml version="1.0" encoding="utf-8" ?>
<Defs>



  <!-- ================ Mantellian granite ================ -->

  <ThingDef ParentName="UglyRockBase" Name="SWCPStone_OrdMantellGranite">
    <defName>SWCPStone_OrdMantellGranite</defName>
    <label>Mantellian granite</label>
    <description>A very hard igneous rock.</description>
    <graphicData>
      <color>(110,95,100)</color>
    </graphicData>
    <statBases>
      <MaxHitPoints>900</MaxHitPoints>
    </statBases>
    <building>
      <biomeSpecific>true</biomeSpecific>
	  <mineableThing>SWCPStoneChunk_OrdMantellGranite</mineableThing>
      <mineableDropChance>0.25</mineableDropChance>
      <smoothedThing>SWCPStoneSmoothed_OrdMantellGranite</smoothedThing>
    </building>
  </ThingDef>

  <ThingDef ParentName="SWCPStone_OrdMantellGranite">
    <defName>SWCPStoneSmoothed_OrdMantellGranite</defName>
    <label>smoothed Mantellian granite</label>
    <description>A very hard igneous rock.</description>
    <uiIconPath>Things/Building/Linked/WallSmooth_MenuIcon</uiIconPath>
    <graphicData>
      <texPath>Things/Building/Linked/RockSmooth_Atlas</texPath>
    </graphicData>
    <statBases>
      <Beauty>1</Beauty>
      <MarketValue>7</MarketValue>
    </statBases>
    <building>
      <isNaturalRock>false</isNaturalRock>
      <canBuildNonEdificesUnder>true</canBuildNonEdificesUnder>
      <artificialForMeditationPurposes>false</artificialForMeditationPurposes>
      <smoothedThing />
      <paintable>true</paintable>
    </building>
    <saveCompressible>false</saveCompressible>
    <repairEffect>Repair</repairEffect>
  </ThingDef>
  
  <ThingDef ParentName="ChunkRockBase">
    <defName>SWCPStoneChunk_OrdMantellGranite</defName>
    <label>Mantellian granite chunk</label>
    <graphicData>
      <color>(110,95,100)</color>
    </graphicData>
    <statBases>
      <Mass>22</Mass>
    </statBases>
    <soundDrop>ChunkRock_Drop</soundDrop>
    <butcherProducts>
      <SWCPStoneBlocks_OrdMantellGranite>20</SWCPStoneBlocks_OrdMantellGranite>
    </butcherProducts>
  </ThingDef>

  <ThingDef ParentName="StoneBlocksBase">
    <defName>SWCPStoneBlocks_OrdMantellGranite</defName>
    <label>Mantellian granite blocks</label>
    <description>Blocks of solid Mantellian granite.</description>
    <graphicData>
      <color>(110,95,100)</color>
    </graphicData>
    <statBases>
      <Mass>1.25</Mass>
      <SharpDamageMultiplier>0.65</SharpDamageMultiplier>
    </statBases>
    <stuffProps>
      <color>(110,95,100)</color>
      <soundImpactBullet>BulletImpact_Ground</soundImpactBullet>
      <soundMeleeHitSharp>MeleeHit_Stone</soundMeleeHitSharp>
      <soundMeleeHitBlunt>MeleeHit_Stone</soundMeleeHitBlunt>
      <soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Stone</soundImpactMelee>
      <stuffAdjective>granite</stuffAdjective>
      <statFactors>
        <MaxHitPoints>1.7</MaxHitPoints>
      </statFactors>
      <canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
    </stuffProps>
  </ThingDef>

  <RecipeDef ParentName="MakeStoneBlocksBase">
    <defName>SWCPRecipe_BlocksOrdMantellGranite</defName>
    <label>make Mantellian granite blocks</label>
    <description>Cuts Mantellian granite chunks into usable blocks.</description>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>SWCPStoneChunk_OrdMantellGranite</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>SWCPStoneChunk_OrdMantellGranite</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <SWCPStoneBlocks_OrdMantellGranite>20</SWCPStoneBlocks_OrdMantellGranite>
    </products>
  </RecipeDef>
  
  
  <TerrainDef ParentName="TileStoneBase">
    <defName>SWCPTerrain_StoneTile_OrdMantellGranite</defName>
    <label>Mantellian granite tile</label>
    <color>(110,95,100)</color>
    <costList>
      <SWCPStoneBlocks_OrdMantellGranite>4</SWCPStoneBlocks_OrdMantellGranite>
    </costList>
  </TerrainDef>
  
  
  <TerrainDef ParentName="FlagstoneBase">
    <defName>SWCPTerrain_Flagstone_OrdMantellGranite</defName>
    <label>Mantellian granite flagstone</label>
    <color>(110,95,100)</color>
    <costList>
      <SWCPStoneBlocks_OrdMantellGranite>4</SWCPStoneBlocks_OrdMantellGranite>
    </costList>
  </TerrainDef>
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
