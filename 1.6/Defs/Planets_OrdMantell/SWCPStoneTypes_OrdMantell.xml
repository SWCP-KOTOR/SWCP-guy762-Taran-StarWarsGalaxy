      <paintable>true</paintable>
    </building>
    <saveCompressible>false</saveCompressible>
    <repairEffect>Repair</repairEffect>
  </ThingDef>
  
  <ThingDef ParentName="ChunkRockBase">
    <defName>SWCPStoneChunk_OrdMantellSlate</defName>
    <label>Mantellian slate chunk</label>
    <graphicData>
      <color>(65,60,65)</color>
    </graphicData>
    <statBases>
      <Mass>18</Mass>
    </statBases>
    <soundDrop>ChunkRock_Drop</soundDrop>
    <butcherProducts>
      <SWCPStoneBlocks_OrdMantellSlate>20</SWCPStoneBlocks_OrdMantellSlate>
