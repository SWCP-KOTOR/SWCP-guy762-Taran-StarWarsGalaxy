  </ThingDef>

  <ThingDef ParentName="StoneBlocksBase">
    <defName>SWCPStoneBlocks_OrdMantellSlate</defName>
    <label>Mantellian slate blocks</label>
    <description>Blocks of solid Mantellian slate.</description>
    <graphicData>
      <color>(65,60,65)</color>
    </graphicData>
    <statBases>
      <Mass>0.9</Mass>
    </statBases>
    <stuffProps>
      <color>(65,60,65)</color>
      <soundImpactBullet>BulletImpact_Ground</soundImpactBullet>
      <soundMeleeHitSharp>MeleeHit_Stone</soundMeleeHitSharp>
      <soundMeleeHitBlunt>MeleeHit_Stone</soundMeleeHitBlunt>
      <soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Stone</soundImpactMelee>
      <stuffAdjective>slate</stuffAdjective>
      <statFactors>
        <Beauty>1.1</Beauty>
        <MaxHitPoints>1.3</MaxHitPoints>
      </statFactors>
      <canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
    </stuffProps>
  </ThingDef>

  <RecipeDef ParentName="MakeStoneBlocksBase">
    <defName>SWCPRecipe_BlocksOrdMantellSlate</defName>
    <label>make Mantellian slate blocks</label>
